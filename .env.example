# =============================================================================
# Copy this file to `.env` (cp .env.example .env). EVERY value below is a
# value YOU choose — they point at containers inside the docker-compose
# network. There are NO external accounts, API keys, or paid services:
# the LLM, the TTS vendor and the audio stitching are all SIMULATED.
# =============================================================================

# --- Postgres (state database) ---------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=pipeline
# Used by the app code. Host `postgres` is the compose service name.
DATABASE_URL=postgresql+psycopg2://app:app@postgres:5432/pipeline

# --- RabbitMQ (message broker) ---------------------------------------------
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F

# --- Redis (cache / locks / idempotency / semaphore) -----------------------
REDIS_URL=redis://redis:6379/0

# --- MinIO (object storage) -------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pipeline

# --- Pipeline tuning --------------------------------------------------------
# Simulated 500-error rate at the parsing step (assignment asks for 15%).
PARSE_FAILURE_RATE=0.15
# Global cap on concurrent TTS "vendor" calls (Constraint A).
TTS_MAX_CONCURRENCY=3
# Retries before a message is dead-lettered (assignment asks for 3).
MAX_RETRIES=3
# Exponential backoff schedule in milliseconds (retry 1, 2, 3).
# Production-like default:
RETRY_BACKOFFS_MS=5000,30000,120000
# FAST DEMO MODE for recording a short video: comment the line above and
# uncomment the one below so a poison pill reaches the DLQ in ~15s, not ~2.5min.
# RETRY_BACKOFFS_MS=2000,4000,6000
# A job stuck in a non-terminal state longer than this (seconds) is resumed
# by the reaper. Covers the "resume on restart" crash-recovery path.
STUCK_JOB_SECONDS=60

# --- Optional: real webhook to SEE the final notification fire --------------
# Leave blank to just log the notification locally. To watch it for real,
# create a free inbox at https://webhook.site and paste the URL here.
DEFAULT_WEBHOOK_URL=
